#!/usr/bin/env bash
set -euo pipefail

repo_root="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
cd "$repo_root"

evidence_path="target/bench_acceptance/section14-benchmark-acceptance.json"
verifier_lock_dir="target/bench_acceptance/.section14.test.lock"
db_bench_sentinel="DB_BENCH: PASS evidence=target/bench_acceptance/section14-benchmark-acceptance.json"
verify_sentinel="BENCH_ACCEPTANCE: PASS evidence=target/bench_acceptance/section14-benchmark-acceptance.json"

fail() {
  local check_id="$1"
  local reason="$2"
  printf 'BENCH_ACCEPTANCE: FAIL check=%s reason=%s\n' "$check_id" "$reason"
  exit 1
}

require_tool() {
  if ! command -v "$1" >/dev/null 2>&1; then
    fail "required_tool" "$1-not-found"
  fi
}

require_tool cargo
require_tool python3

process_is_running() {
  local pid="$1"
  if [[ -z "$pid" || ! "$pid" =~ ^[0-9]+$ || "$pid" == "0" ]]; then
    return 1
  fi
  kill -0 "$pid" >/dev/null 2>&1
}

remove_stale_verifier_lock() {
  local pid_file="$verifier_lock_dir/pid"
  if [[ -f "$pid_file" ]]; then
    local pid
    pid="$(cat "$pid_file" 2>/dev/null || true)"
    if ! process_is_running "$pid"; then
      rm -rf "$verifier_lock_dir"
      return
    fi
  fi
  python3 - "$verifier_lock_dir" <<'PY'
import os
import shutil
import sys
import time

path = sys.argv[1]
try:
    age = time.time() - os.stat(path).st_mtime
except FileNotFoundError:
    sys.exit(0)
if age > 600:
    shutil.rmtree(path, ignore_errors=True)
PY
}

mkdir -p "target/bench_acceptance"
lock_acquired=0
for _ in $(seq 1 3600); do
  if mkdir "$verifier_lock_dir" 2>/dev/null; then
    lock_acquired=1
    printf '%s\n' "$$" >"$verifier_lock_dir/pid"
    trap 'rm -rf "$verifier_lock_dir" 2>/dev/null || true' EXIT
    break
  fi
  remove_stale_verifier_lock
  sleep 0.1
done
if [[ "$lock_acquired" != "1" ]]; then
  fail "bench_lock" "timed-out-acquiring-verifier-lock"
fi

rm -f "$evidence_path"

stderr_path="$(mktemp)"
set +e
db_stdout="$(cargo run --quiet --bin db -- bench 2>"$stderr_path")"
db_status=$?
set -e
db_stderr="$(cat "$stderr_path")"
rm -f "$stderr_path"

if [[ "$db_status" -ne 0 ]]; then
  printf '%s\n' "$db_stdout"
  fail "db_bench" "db-bench-exited-$db_status"
fi
if [[ -n "$db_stderr" ]]; then
  fail "db_bench_stderr" "db-bench-wrote-stderr"
fi
if [[ "$db_stdout" != "$db_bench_sentinel" ]]; then
  fail "db_bench_sentinel" "unexpected-db-bench-stdout"
fi
if [[ ! -f "$evidence_path" ]]; then
  fail "evidence_file" "missing-$evidence_path"
fi

python3 - "$evidence_path" "$db_bench_sentinel" "$verify_sentinel" <<'PY'
import json
import os
import sys
import tempfile

path, db_bench_sentinel, verify_sentinel = sys.argv[1:4]
with open(path, "r", encoding="utf-8") as handle:
    evidence = json.load(handle)

def fail(check_id, reason):
    print(f"BENCH_ACCEPTANCE: FAIL check={check_id} reason={reason}")
    sys.exit(1)

required_top_level = [
    "schema_version",
    "artifact",
    "row_count",
    "primary_key_type",
    "secondary_index_column",
    "secondary_index_name",
    "text_bytes_min",
    "text_bytes_max",
    "deterministic_seed",
    "warmup_runs",
    "measurement_runs",
    "runtime_cap_seconds",
    "commands",
    "workload",
    "raw_measurements",
    "metrics",
    "recovery",
    "index_use_evidence",
    "hard_fail_checks",
    "result",
]
for key in required_top_level:
    if key not in evidence:
        fail("required_field", f"missing-{key}")

expected_dataset = {
    "artifact": "v1-section14-benchmark-acceptance",
    "row_count": 100000,
    "primary_key_type": "INTEGER",
    "secondary_index_column": "group_key",
    "secondary_index_name": "idx_section14_bench_group_key",
    "text_bytes_min": 8,
    "text_bytes_max": 64,
    "deterministic_seed": 140014,
    "warmup_runs": 1,
    "measurement_runs": 5,
}
for key, expected in expected_dataset.items():
    if evidence.get(key) != expected:
        fail("dataset_contract", f"{key}-mismatch")
if evidence.get("runtime_cap_seconds", 999999) > 300:
    fail("runtime_cap_seconds", "above-300")

commands = evidence["commands"]
db_bench = commands.get("db_bench", {})
if db_bench.get("status") != "pass" or db_bench.get("evidence_path") != path:
    fail("commands_db_bench", "db-bench-command-evidence-mismatch")
if db_bench.get("stdout_sentinel") != db_bench_sentinel:
    fail("commands_db_bench", "db-bench-sentinel-mismatch")

workload = evidence["workload"]
expected_primary_keys = [((140014 + n * 9973) % 100000) + 1 for n in range(100)]
expected_equality_keys = [((140014 + n * 433) % 10000) + 1 for n in range(100)]
expected_windows = [
    {"low": ((140014 + n * 137) % 9950) + 1, "high": ((140014 + n * 137) % 9950) + 50}
    for n in range(50)
]
primary = workload.get("primary_key_lookup", {})
equality = workload.get("secondary_equality", {})
ranges = workload.get("secondary_range", {})
if primary.get("n_start") != 0 or primary.get("n_end") != 99 or primary.get("count_per_run") != 100:
    fail("workload_contract", "primary-query-rule-mismatch")
if primary.get("keys") != expected_primary_keys:
    fail("workload_contract", "primary-query-keys-mismatch")
if equality.get("n_start") != 0 or equality.get("n_end") != 99 or equality.get("count_per_run") != 100:
    fail("workload_contract", "equality-query-rule-mismatch")
if equality.get("keys") != expected_equality_keys:
    fail("workload_contract", "equality-query-keys-mismatch")
if ranges.get("n_start") != 0 or ranges.get("n_end") != 49 or ranges.get("count_per_run") != 50:
    fail("workload_contract", "range-query-rule-mismatch")
if ranges.get("range_window_distinct_group_keys") != 50:
    fail("workload_contract", "range-window-size-mismatch")
if abs(float(ranges.get("selectivity_fraction", -1)) - 0.005) > 0.000001:
    fail("workload_contract", "range-selectivity-mismatch")
if ranges.get("windows") != expected_windows:
    fail("workload_contract", "range-windows-mismatch")
scan_comparison = workload.get("scan_comparison", {})
if scan_comparison.get("mode") != "explicit_harness_full_scan":
    fail("workload_contract", "scan-comparison-mode-mismatch")
for key in ["same_dataset", "same_predicate", "result_hash_required"]:
    if scan_comparison.get(key) is not True:
        fail("workload_contract", f"scan-comparison-{key}-not-true")
if workload.get("scan_comparison_mode") != "explicit_harness_full_scan":
    fail("workload_contract", "legacy-scan-comparison-mode-mismatch")
if workload.get("measured_query_count_per_run") != 400 or workload.get("measured_query_count_total") != 2000:
    fail("workload_contract", "measured-query-count-mismatch")
counts_by_run = workload.get("measured_counts_by_run")
if not isinstance(counts_by_run, list) or len(counts_by_run) != 5:
    fail("workload_contract", "measured-counts-by-run-missing")
for expected_run, counts in enumerate(counts_by_run, start=1):
    expected_counts = {
        "run": expected_run,
        "primary_key_lookup": 100,
        "secondary_equality_indexed": 100,
        "secondary_equality_scan": 100,
        "range_indexed": 50,
        "range_scan": 50,
        "total": 400,
    }
    if counts != expected_counts:
        fail("workload_contract", f"measured-counts-run-{expected_run}-mismatch")
if workload.get("sequential_inserts") != 100000:
    fail("workload_contract", "sequential-inserts-mismatch")
if workload.get("recovery_after_committed_transactions") != 10000:
    fail("workload_contract", "recovery-transaction-count-mismatch")

metrics = evidence["metrics"]
raw = evidence["raw_measurements"]
for key, expected_len in [
    ("primary_key_lookup_run_ms", 5),
    ("secondary_equality_indexed_run_ms", 5),
    ("secondary_equality_scan_run_ms", 5),
    ("range_indexed_run_ms", 5),
    ("range_scan_run_ms", 5),
]:
    values = raw.get(key)
    if not isinstance(values, list) or len(values) != expected_len:
        fail("raw_measurements", f"{key}-missing-or-wrong-count")
    if any(float(value) <= 0 for value in values):
        fail("raw_measurements", f"{key}-non-positive")
if float(raw.get("runtime_ms", 0)) <= 0:
    fail("runtime_cap_seconds", "missing-runtime-ms")
if float(raw["runtime_ms"]) > float(evidence["runtime_cap_seconds"]) * 1000.0:
    fail("runtime_cap_seconds", "runtime-cap-exceeded")

def median(values):
    ordered = sorted(float(value) for value in values)
    return ordered[len(ordered) // 2]

for key in [
    "sequential_insert_elapsed_ms",
    "insert_throughput_rows_per_sec",
    "primary_key_lookup_median_ms",
    "secondary_equality_indexed_median_ms",
    "secondary_equality_scan_median_ms",
    "range_indexed_median_ms",
    "range_scan_median_ms",
    "equality_index_speedup",
    "range_index_speedup",
    "db_file_bytes",
    "wal_file_bytes",
]:
    if key not in metrics:
        fail("metrics", f"missing-{key}")
    if float(metrics[key]) <= 0:
        fail("metrics", f"non-positive-{key}")

recomputed = {
    "primary_key_lookup_median_ms": median(raw["primary_key_lookup_run_ms"]),
    "secondary_equality_indexed_median_ms": median(raw["secondary_equality_indexed_run_ms"]),
    "secondary_equality_scan_median_ms": median(raw["secondary_equality_scan_run_ms"]),
    "range_indexed_median_ms": median(raw["range_indexed_run_ms"]),
    "range_scan_median_ms": median(raw["range_scan_run_ms"]),
}
recomputed["equality_index_speedup"] = (
    recomputed["secondary_equality_scan_median_ms"]
    / recomputed["secondary_equality_indexed_median_ms"]
)
recomputed["range_index_speedup"] = (
    recomputed["range_scan_median_ms"] / recomputed["range_indexed_median_ms"]
)
for key, expected in recomputed.items():
    if abs(float(metrics[key]) - expected) > 0.01:
        fail(key, "metric-does-not-match-raw-measurements")

if recomputed["equality_index_speedup"] < 5.0:
    fail("equality_speedup", "below-5.0")
if recomputed["range_index_speedup"] < 3.0:
    fail("range_speedup", "below-3.0")

recovery = evidence["recovery"]
if recovery.get("committed_transaction_count") != 10000:
    fail("recovery_contract", "committed-transaction-count-mismatch")
if recovery.get("wal_replay_applied_records") != 10000:
    fail("recovery_contract", "wal-replay-applied-record-count-mismatch")
if recovery.get("recovered_row_count") != 10000:
    fail("recovery_contract", "recovered-row-count-mismatch")
if not recovery.get("representative_lookup_result", {}).get("matched"):
    fail("recovery_contract", "representative-lookup-mismatch")
recovery_ms = float(recovery.get("recovery_ms", 0))
wal_file_bytes = float(recovery.get("wal_file_bytes", metrics.get("wal_file_bytes", 0)))
if recovery_ms <= 0 or recovery_ms > max(2000.0, wal_file_bytes / 4096.0):
    fail("recovery_proportionality", "bound-exceeded")

index_entries = evidence["index_use_evidence"]
if not isinstance(index_entries, list):
    fail("index_use_evidence", "not-a-list")
equality_entries = [item for item in index_entries if item.get("query_kind") == "secondary_equality"]
range_entries = [item for item in index_entries if item.get("query_kind") == "secondary_range"]
if len(equality_entries) != 100:
    fail("indexed_equality_no_full_scan", f"expected-100-equality-proofs-got-{len(equality_entries)}")
if len(range_entries) != 50:
    fail("indexed_range_no_full_scan", f"expected-50-range-proofs-got-{len(range_entries)}")
expected_equality_predicates = [f"group_key = {key}" for key in expected_equality_keys]
expected_range_predicates = [
    f"group_key BETWEEN {window['low']} AND {window['high']}" for window in expected_windows
]
if [item.get("predicate") for item in equality_entries] != expected_equality_predicates:
    fail("indexed_equality_no_full_scan", "equality-proof-predicate-coverage-mismatch")
if [item.get("predicate") for item in range_entries] != expected_range_predicates:
    fail("indexed_range_no_full_scan", "range-proof-predicate-coverage-mismatch")

for item in index_entries:
    kind = item.get("query_kind")
    if kind == "secondary_equality":
        if item.get("observed_access_path") != "secondary_index_equality":
            fail("indexed_equality_no_full_scan", "full-scan-observed")
    if kind == "secondary_range":
        if item.get("observed_access_path") != "secondary_index_range":
            fail("indexed_range_no_full_scan", "full-scan-observed")
    if item.get("used_index") != "idx_section14_bench_group_key":
        fail("index_use_evidence", "index-name-mismatch")
    if item.get("scan_rejected") is not True:
        fail("index_use_evidence", "scan-not-rejected")
    if item.get("result_hash_match") is not True:
        fail("index_use_evidence", "result-hash-mismatch")
    if item.get("indexed_result_count") != item.get("scan_result_count"):
        fail("index_use_evidence", "result-count-mismatch")
    if item.get("indexed_result_hash") != item.get("scan_result_hash"):
        fail("index_use_evidence", "result-hash-value-mismatch")

checks = {item.get("check_id"): item.get("status") for item in evidence["hard_fail_checks"]}
for check_id in [
    "dataset_contract",
    "equality_speedup",
    "range_speedup",
    "indexed_equality_no_full_scan",
    "indexed_range_no_full_scan",
    "recovery_proportionality",
    "wal_replay_applied_records",
    "no_retry_required",
]:
    if checks.get(check_id) != "pass":
        fail(check_id, "hard-fail-check-not-pass")

evidence["commands"]["verify_bench_acceptance"] = {
    "status": "pass",
    "evidence_path": path,
    "stdout_sentinel": verify_sentinel,
}
evidence["result"] = "pass"
parent = os.path.dirname(path) or "."
fd, tmp_path = tempfile.mkstemp(prefix=".section14-final-", suffix=".json.tmp", dir=parent)
try:
    with os.fdopen(fd, "w", encoding="utf-8") as handle:
        json.dump(evidence, handle, indent=2, sort_keys=False)
        handle.write("\n")
        handle.flush()
        os.fsync(handle.fileno())
    os.replace(tmp_path, path)
finally:
    if os.path.exists(tmp_path):
        os.unlink(tmp_path)
PY

printf '%s\n' "$verify_sentinel"
